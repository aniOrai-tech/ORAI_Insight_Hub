# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/orai_insight_hub

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=ORAI Insight Hub <noreply@orai.com>

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Upload path
UPLOAD_PATH=./uploads
